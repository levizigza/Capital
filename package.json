{
    "name": "capital",
    "private": true,
    "version": "0.0.0",
    "homepage": "https://levizigza.github.io/Capital/",
    "type": "module",
    "scripts": {
        "dev": "node --require ./scripts/patch-fs-retry.cjs ./node_modules/vite/bin/vite.js",
        "kill": "fuser -k 5000/tcp",
        "build": "tsc -b --noCheck && vite build",
        "lint": "eslint .",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:smoke": "playwright test e2e/islands-smoke.spec.ts",
        "test:qa": "vitest run src/qa",
        "content:validate": "node scripts/validate-content.mjs",
        "assets:xelu-prompts": "node scripts/sync-xelu-prompts.mjs",
        "assets:validate": "node scripts/validate-asset-registry.mjs",
        "assets:export-credits": "node scripts/export-asset-credits.mjs",
        "assets:check": "npm run assets:validate && npm run assets:export-credits",
        "pixel:sample": "node scripts/generate-sample-npc-sprites.mjs",
        "pixel:pack": "node scripts/pack-pixel-atlas.mjs",
        "prebuild": "npm run assets:check",
        "optimize": "vite optimize",
        "preview": "vite preview"
    },
